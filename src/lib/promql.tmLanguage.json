{
  "name": "promql",
  "scopeName": "source.promql",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#label-selector" },
    { "include": "#duration" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#function" },
    { "include": "#operator" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "match": "#.*$",
      "name": "comment.line.number-sign.promql"
    },
    "string": {
      "name": "string.quoted.double.promql",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "match": "\\\\.", "name": "constant.character.escape.promql" }
      ]
    },
    "duration": {
      "match": "\\b(?:\\d+(?:ms|s|m|h|d|w|y))+\\b",
      "name": "constant.numeric.duration.promql"
    },
    "number": {
      "match": "\\b\\d+(?:\\.\\d+)?\\b",
      "name": "constant.numeric.promql"
    },
    "keyword": {
      "match": "\\b(sum|avg|min|max|count|count_values|topk|bottomk|quantile|stddev|stdvar|group|by|without|on|ignoring|group_left|group_right|offset|bool|and|or|unless|start|end)\\b",
      "name": "keyword.control.promql"
    },
    "function": {
      "match": "\\b(rate|irate|increase|delta|deriv|predict_linear|histogram_quantile|histogram_count|histogram_sum|absent|absent_over_time|changes|resets|label_replace|label_join|vector|scalar|time|clamp|clamp_min|clamp_max|sort|sort_desc|avg_over_time|max_over_time|min_over_time|sum_over_time|count_over_time|quantile_over_time|stddev_over_time|last_over_time|present_over_time|round|ceil|floor|abs|exp|ln|log2|log10|sqrt|sgn|year|month|day_of_month|day_of_week|hour|minute|days_in_month|timestamp|pi|rad|deg|sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|asinh|acosh|atanh)(?=\\s*\\()",
      "name": "support.function.promql"
    },
    "operator": {
      "match": "(=~|!~|==|!=|<=|>=|<|>|=|\\+|-|\\*|/|%|\\^)",
      "name": "keyword.operator.promql"
    },
    "identifier": {
      "match": "\\b[a-zA-Z_][a-zA-Z_0-9:]*\\b",
      "name": "variable.other.promql"
    },
    "label-selector": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.braces.begin.promql" } },
      "endCaptures": { "0": { "name": "punctuation.section.braces.end.promql" } },
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z_0-9]*)\\s*(=~|!~|!=|=)",
          "captures": {
            "1": { "name": "entity.other.attribute-name.promql" },
            "2": { "name": "keyword.operator.promql" }
          }
        },
        { "include": "#string" },
        { "include": "#comment" }
      ]
    }
  }
}
