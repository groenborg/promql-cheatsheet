---
import "~/styles/fonts.css";
import "@fontsource/jetbrains-mono/latin-400.css";
import "@fontsource/jetbrains-mono/latin-500.css";
import "@fontsource/jetbrains-mono/latin-600.css";
import "~/styles/tokens.css";
import "~/styles/cheatsheet.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
	title: string;
	description?: string;
	image?: string;
	path?: string;
	schema?: "home" | "article";
	datePublished?: string;
	dateModified?: string;
}

const {
	title,
	description,
	image = "/og.jpg",
	path = Astro.url.pathname,
	schema,
	datePublished,
	dateModified,
} = Astro.props;

const canonical = new URL(path, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const ogAlt =
	"PromQL Cheatsheet — Everything you need to write PromQL, on one page.";
const siteUrl = Astro.site?.href ?? "https://promql.fyi/";

const websiteSchema = {
	"@type": "WebSite",
	"@id": `${siteUrl}#website`,
	url: siteUrl,
	name: "PromQL Cheatsheet",
	description:
		"A modern reference for the Prometheus query language — types, selectors, operators, aggregations, functions, time syntax, and the gotchas you only learn at 3am.",
	inLanguage: "en",
};

const articleSchema = schema === "article"
	? {
			"@type": "TechArticle",
			"@id": `${canonical}#article`,
			headline: title,
			description,
			url: canonical,
			image: ogImage,
			inLanguage: "en",
			about: "PromQL (Prometheus Query Language)",
			proficiencyLevel: "Beginner, Intermediate",
			...(datePublished && { datePublished }),
			...(dateModified && { dateModified }),
			author: { "@type": "Organization", name: "promql.fyi", url: siteUrl },
			publisher: { "@type": "Organization", name: "promql.fyi", url: siteUrl },
			isPartOf: { "@id": `${siteUrl}#website` },
		}
	: null;

const jsonLd = schema
	? {
			"@context": "https://schema.org",
			"@graph": [websiteSchema, articleSchema].filter(Boolean),
		}
	: null;
---

<!doctype html>
<html lang="en" data-theme="light" data-density="comfortable">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="promql.fyi" />
    <meta property="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogAlt} />

    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <Analytics />
    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem("promql-theme");
          if (theme === "light" || theme === "dark") {
            document.documentElement.dataset.theme = theme;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
