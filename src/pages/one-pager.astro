---
import Print from "~/layouts/Print.astro";
import Printer from "~/components/icons/Printer.astro";
import OnePagerSection from "~/components/OnePagerSection.astro";
import { sections } from "~/content/one-pager";
---

<Print title="PromQL · One-Pager">
  <div class="toolbar">
    <a href="/">← Back to full cheatsheet</a>
    <span class="spacer"></span>
    <span style="color:var(--ink-3); font-size:12px"
      >A4 portrait · two-color · dense</span
    >
    <button id="print-btn" type="button">
      <Printer size={12} />
      Print / Save PDF
    </button>
  </div>

  <div class="sheet">
    <div class="head">
      <div class="head-l">
        <h1><em>PromQL</em> Cheatsheet</h1>
        <p>
          The Prometheus query language at a glance — types, selectors,
          operators, functions, and the gotchas. Beginner essentials in <strong
            >black</strong
          >, advanced in <strong style="color:var(--accent)">accent</strong>.
        </p>
      </div>
      <div class="head-r">
        <span class="mark">v2.x</span><br />
        one-pager · A4<br />
        print at 100%<br />
      </div>
    </div>

    <div class="cols">
      {sections.map((s) => <OnePagerSection section={s} />)}
    </div>

    <div class="foot">
      <span>PromQL · v2.x reference</span>
      <span>print at 100% / fit-to-page</span>
      <span>prometheus.io/docs/prometheus/latest/querying</span>
    </div>
  </div>
</Print>

<script>
  document
    .getElementById("print-btn")
    ?.addEventListener("click", () => window.print());
</script>
