---
interface Props {
  id: string;
  number: string;
  title: string;
  subtitle?: string;
  tall?: boolean;
}

const { id, number, title, subtitle, tall = false } = Astro.props;
---
<section class="cs" id={id} aria-labelledby={`${id}-title`}>
  <header class="sec-head">
    <span class="sec-num" aria-hidden="true">{number}</span>
    <h2 id={`${id}-title`}>{title}</h2>
    {subtitle && <span class="sec-sub">{subtitle}</span>}
  </header>
  <div class:list={['grid', { tall }]}>
    <slot />
  </div>
</section>
