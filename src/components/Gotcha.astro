---
import type { Gotcha } from '~/content/types';

interface Props {
  gotcha: Gotcha;
}

const { gotcha } = Astro.props;
---
<article class="row gotcha" data-keys={gotcha.keys}>
  <header class="row-title">
    <h3 set:html={gotcha.title} />
  </header>
  <p set:html={gotcha.description} />
</article>
